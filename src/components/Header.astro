---
// src/components/Header.astro
import { SITE_CONFIG } from '@/lib/constants';
import ThemeToggle from '@/components/ThemeToggle';
---

<header class='header sticky top-0 z-40 w-full border-b' style='border-color: var(--gris-presse); background: var(--noir);'>
  <div class='header_wrap container mx-auto flex h-16 items-center px-4 sm:px-6 md:px-8'>
    <div class='flex flex-1'>
      <a href='/' class='header__logo'>
        La <span>Déraison</span>
      </a>
    </div>
    <nav class='header__nav'>
      <ul class='header__nav-links'>
        <li><a href='/lettres'>Les Lettres</a></li>
        <li><a href='/abonnement'>La Fosse</a></li>
      </ul>
    </nav>
    <ThemeToggle client:load />
  </div>
</header>

<style lang='scss'>
  .header {
    &__logo {
      font-family: var(--font-serif);
      font-size: 0.95rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--parchemin);
      text-decoration: none;
      transition: color 0.2s;

      &:hover {
        color: var(--sang);
      }

      span {
        color: var(--sang);
      }
    }

    &__nav {
      flex: 1;
      display: flex;
      justify-content: flex-end;
    }

    &__nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      margin: 0;
      padding: 0;

      a {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--parchemin);
        text-decoration: none;
        transition: color 0.2s;

        &:hover {
          color: var(--sang);
        }
      }
    }
  }

  @media (max-width: 640px) {
    .header__nav-links {
      display: none;
    }
  }
</style>
