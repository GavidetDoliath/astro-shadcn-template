---
// src/components/Header.astro
import ThemeToggle from '@/components/ThemeToggle';
---

<header class='header sticky top-0 z-40 w-full border-b'>
  <div class='header__wrap'>
    <!-- Logo -->
    <a href='/' class='header__logo'>
      La <span>Déraison</span>
    </a>

    <!-- Nav centre (desktop) -->
    <nav class='header__nav' aria-label='Navigation principale'>
      <ul class='header__nav-links'>
        <li><a href='/lettres'>Les Lettres</a></li>
        <li><a href='/abonnement'>La Fosse</a></li>
      </ul>
    </nav>

    <!-- Droite : toggle + hamburger -->
    <div class='header__right'>
      <ThemeToggle client:load />
      <button class='header__hamburger' aria-label='Menu' aria-expanded='false' aria-controls='mobile-menu'>
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Menu mobile -->
  <div class='header__mobile-menu' id='mobile-menu' aria-hidden='true'>
    <ul>
      <li><a href='/lettres'>Les Lettres</a></li>
      <li><a href='/abonnement'>La Fosse</a></li>
    </ul>
  </div>
</header>

<script>
  const btn = document.querySelector('.header__hamburger') as HTMLButtonElement;
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const open = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!open));
    menu?.setAttribute('aria-hidden', String(open));
    btn.classList.toggle('is-open', !open);
    menu?.classList.toggle('is-open', !open);
  });
</script>

<style lang='scss'>
  .header {
    border-color: var(--gris-presse);
    background: var(--noir);

    &__wrap {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      max-width: 1280px;
      margin: 0 auto;
      height: 4rem;
      padding: 0 2rem;

      @media (max-width: 640px) {
        padding: 0 1rem;
      }
    }

    &__logo {
      font-family: var(--font-serif);
      font-size: 0.95rem;
      font-weight: 900;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--parchemin);
      text-decoration: none;
      transition: color 0.2s;

      &:hover { color: var(--sang); }
      span { color: var(--sang); }
    }

    &__nav {
      display: flex;
      justify-content: center;

      @media (max-width: 640px) {
        display: none;
      }
    }

    &__nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      margin: 0;
      padding: 0;

      a {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--parchemin);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s;

        &:hover { border-bottom-color: var(--sang); }
      }
    }

    &__right {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 0.5rem;
    }

    &__hamburger {
      display: none;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
      width: 2rem;
      height: 2rem;
      padding: 0;
      background: transparent;
      border: none;
      cursor: pointer;

      @media (max-width: 640px) {
        display: flex;
      }

      span {
        display: block;
        width: 20px;
        height: 2px;
        background: var(--parchemin);
        transition: transform 0.25s, opacity 0.25s;
        transform-origin: center;
      }

      &.is-open {
        span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
        span:nth-child(2) { opacity: 0; transform: scaleX(0); }
        span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      }
    }

    &__mobile-menu {
      display: none;
      border-top: 1px solid var(--gris-presse);

      @media (max-width: 640px) {
        display: block;
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease;

        &.is-open {
          max-height: 200px;
        }
      }

      ul {
        list-style: none;
        margin: 0;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      a {
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--parchemin);
        text-decoration: none;

        &:hover { color: var(--sang); }
      }
    }
  }
</style>
