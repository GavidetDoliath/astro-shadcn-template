---
// src/components/ArticlesSection.astro
import ArticleCard from '@/components/ArticleCard.astro';
import { getArticles } from '@/lib/articles';

// RГ©cupГЁre les 6 derniers articles depuis Supabase
const articles = await getArticles(6, 'featured');
---

<section class="articles">
  <div class="articles__inner">
    <!-- Header -->
    <div class="articles__header">
      <div class="articles__label">вҖ” Les Lettres</div>
      <div class="articles__rule" />
      <h2 class="articles__title">Derniers Pamphlets</h2>
    </div>

    <!-- Bento Grid -->
    <div class="articles__grid">
      {articles.map((article, index) => {
        // Marquer les 2 premiers articles importants comme "featured"
        const isFeatured = index < 2;
        return <ArticleCard article={article} featured={isFeatured} />;
      })}
    </div>

    <!-- CTA -->
    <div class="articles__cta">
      <a href="/lettres" class="articles__link">Voir tous les articles вҶ’</a>
    </div>
  </div>
</section>

<style lang="scss">
  .articles {
    position: relative;
    width: 100%;
    background: var(--noir);
    padding: clamp(4rem, 10vh, 10rem) clamp(1.5rem, 8vw, 8rem);
    border-top: 1px solid var(--gris-presse);
    overflow: hidden;
  }

  .articles__inner {
    position: relative;
    z-index: 1;
    max-width: 1400px;
    margin: 0 auto;
  }

  .articles__header {
    margin-bottom: clamp(2.5rem, 6vh, 4rem);
  }

  .articles__label {
    font-family: var(--font-mono);
    font-size: clamp(0.6rem, 1vw, 0.75rem);
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--rouille);
    margin-bottom: 1rem;
  }

  .articles__rule {
    width: 3rem;
    height: 2px;
    background: var(--sang);
    margin-bottom: 1.5rem;
  }

  .articles__title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 0.95;
    color: var(--parchemin);
    margin: 0;
  }

  .articles__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(3, 300px);
    gap: clamp(0.75rem, 2vw, 1.5rem);
    margin-bottom: clamp(2.5rem, 6vh, 4rem);

    /*
      Bento sans trous (4 col Г— 3 row = 12 cells):
      в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”җ
      в”Ӯ  1   в”Ӯ 2  в”Ӯ 3  в”Ӯ
      в”Ӯ      в”ңв”Җв”Җв”Җв”Җв”Ө    в”Ӯ
      в”Ӯ      в”Ӯ 4  в”Ӯ    в”Ӯ
      в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”¬в”Җв”ҙв”Җв”Җв”Җв”Җв”Ө  вҶҗ non, voir ci-dessous
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ

      в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”¬в”Җв”Җв”җ
      в”Ӯ  1  в”Ӯ  1  в”Ӯ2 в”Ӯ3 в”Ӯ  rows 1-2
      в”Ӯ  1  в”Ӯ  1  в”Ӯ4 в”Ӯ3 в”Ӯ
      в”ңв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”јв”Җв”Җв”ҙв”Җв”Җв”Ө
      в”Ӯ  5  в”Ӯ  5  в”Ӯ  6  в”Ӯ  row 3
      в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
    */
    > :nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
    > :nth-child(2) { grid-column: 3 / 4; grid-row: 1 / 2; }
    > :nth-child(3) { grid-column: 4 / 5; grid-row: 1 / 3; }
    > :nth-child(4) { grid-column: 3 / 4; grid-row: 2 / 3; }
    > :nth-child(5) { grid-column: 1 / 3; grid-row: 3 / 4; }
    > :nth-child(6) { grid-column: 3 / 5; grid-row: 3 / 4; }
  }

  .articles__cta {
    text-align: center;
  }

  .articles__link {
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1.2vw, 0.8rem);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--parchemin);
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-block;

    &:hover {
      color: var(--sang);
    }
  }

  /* Responsive: tablette вҖ” 3 col Г— 3 rows, sans trous */
  @media (max-width: 1100px) {
    .articles__grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: repeat(3, 260px);

      /*
        в”Ңв”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”Җв”Җв”Җв”¬в”Җв”Җв”җ
        в”Ӯ  1  в”Ӯ  1  в”Ӯ2 в”Ӯ  rows 1-2
        в”Ӯ  1  в”Ӯ  1  в”Ӯ3 в”Ӯ
        в”ңв”Җв”Җв”¬в”Җв”Җв”ҙв”Җв”Җв”¬в”Җв”Җв”ҙв”Җв”Җв”Ө
        в”Ӯ4 в”Ӯ  5  в”Ӯ  6  в”Ӯ  row 3
        в””в”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҙв”Җв”Җв”Җв”Җв”Җв”ҳ
      */
      > :nth-child(1) { grid-column: 1 / 3; grid-row: 1 / 3; }
      > :nth-child(2) { grid-column: 3 / 4; grid-row: 1 / 2; }
      > :nth-child(3) { grid-column: 3 / 4; grid-row: 2 / 3; }
      > :nth-child(4) { grid-column: 1 / 2; grid-row: 3 / 4; }
      > :nth-child(5) { grid-column: 2 / 3; grid-row: 3 / 4; }
      > :nth-child(6) { grid-column: 3 / 4; grid-row: 3 / 4; }
    }
  }

  /* Responsive: mobile вҖ” 1 col */
  @media (max-width: 640px) {
    .articles__grid {
      grid-template-columns: 1fr;
      grid-template-rows: none;
      grid-auto-rows: 260px;

      > :nth-child(1),
      > :nth-child(2),
      > :nth-child(3),
      > :nth-child(4),
      > :nth-child(5),
      > :nth-child(6) {
        grid-column: auto;
        grid-row: auto;
      }
    }
  }
</style>
