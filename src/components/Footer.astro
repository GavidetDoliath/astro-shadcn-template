---
// src/components/Footer.astro
---

<footer class="footer">
  <div class="footer__divider" />

  <div class="footer__content">
    <div class="footer__col footer__col--logo">
      <div class="footer__logo">
        La <span>Déraison</span>
      </div>
      <div class="footer__tagline">Guérilla littéraire</div>
    </div>

    <div class="footer__col footer__col--nav">
      <nav class="footer__nav">
        <ul class="footer__nav-list">
          <li><a href="/lettres">Les Lettres</a></li>
          <li><a href="/pamphlets">Pamphlets</a></li>
          <li><a href="/apropos">La Fosse</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer__col footer__col--meta">
      <div class="footer__meta">Paraît sans autorisation — MMXXIV</div>
    </div>
  </div>

  <div class="footer__bottom-bar">
    <span>© La Déraison · Service militaire de la langue française</span>
  </div>
</footer>

<style lang="scss">
  .footer {
    position: relative;
    background: var(--encre);
  }

  .footer__divider {
    width: 100%;
    height: 1px;
    background: var(--gris-presse);
  }

  .footer__content {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 5vw, 3rem);
    padding: clamp(2.5rem, 6vh, 5rem) clamp(1.5rem, 8vw, 8rem);
  }

  .footer__col {
    &--logo {
      grid-column: 1;
    }

    &--nav {
      grid-column: 1;
    }

    &--meta {
      grid-column: 1;
    }
  }

  .footer__logo {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(0.9rem, 2vw, 1.25rem);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--parchemin);
    margin-bottom: 0.5rem;

    span {
      color: var(--sang);
    }
  }

  .footer__tagline {
    font-family: var(--font-body);
    font-style: italic;
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    color: var(--beige-pali);
  }

  .footer__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    a {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--beige-pali);
      text-decoration: none;
      transition: color 0.2s;

      &:hover {
        color: var(--parchemin);
      }
    }
  }

  .footer__meta {
    font-family: var(--font-mono);
    font-size: clamp(0.65rem, 1vw, 0.8rem);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--beige-pali);
  }

  .footer__bottom-bar {
    border-top: 1px solid var(--gris-presse);
    padding: clamp(1.5rem, 3vh, 2.5rem) clamp(1.5rem, 8vw, 8rem);
    text-align: center;

    span {
      font-family: var(--font-mono);
      font-size: 0.55rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--muted-foreground);
    }
  }

  @media (min-width: 768px) {
    .footer__content {
      grid-template-columns: 1fr 1fr 1fr;
      gap: clamp(2rem, 6vw, 4rem);
    }

    .footer__col {
      &--logo {
        grid-column: 1;
      }

      &--nav {
        grid-column: 2;
      }

      &--meta {
        grid-column: 3;
        text-align: right;
      }
    }

    .footer__nav-list {
      flex-direction: row;
      gap: 2rem;
    }
  }
</style>
