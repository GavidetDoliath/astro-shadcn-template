---
import type { UserProfile } from '@/lib/auth';

interface Props {
  accessLevel: 'public' | 'subscriber_free' | 'subscriber_paid';
  user: UserProfile | null;
  excerpt?: string;
}

const { accessLevel, user, excerpt } = Astro.props;

const isLoggedIn = user !== null;
const isPaidRequired = accessLevel === 'subscriber_paid';
const isFreeRequired = accessLevel === 'subscriber_free';

// Determine CTA button text and link
let ctaText = 'Abonnez-vous';
let ctaLink = '/inscription';

if (!isLoggedIn) {
  ctaText = 'Se connecter ou s\'inscrire';
  ctaLink = '/connexion?next=' + encodeURIComponent(Astro.url.pathname);
} else if (isPaidRequired) {
  ctaText = 'Passer à l\'abonnement payant';
  ctaLink = '/abonnement';
} else if (isFreeRequired) {
  ctaText = 'Créer un compte gratuit';
  ctaLink = '/inscription';
}

// Determine message
let message = '';
if (isPaidRequired) {
  message = 'Cet article est réservé aux abonnés premium. Passez à l\'abonnement payant pour accéder.';
} else if (isFreeRequired && !isLoggedIn) {
  message = 'Connectez-vous ou inscrivez-vous pour lire cet article.';
} else {
  message = 'Contenu réservé aux abonnés.';
}
---

<div class="relative">
  <!-- Blurred excerpt preview -->
  {excerpt && (
    <div class="prose prose-sm max-w-none mb-8 select-none pointer-events-none">
      <div class="blur-sm opacity-50">
        <p set:html={excerpt} />
      </div>
    </div>
  )}

  <!-- Access gate overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 to-white flex items-center justify-center min-h-[400px]">
    <div class="bg-white rounded-lg border border-gray-200 shadow-lg p-8 max-w-md text-center space-y-6">
      <!-- Lock icon -->
      <div class="text-5xl">
        {isPaidRequired ? '⭐' : '🔒'}
      </div>

      <!-- Message -->
      <div class="space-y-2">
        <h3 class="text-2xl font-bold">
          {isPaidRequired ? 'Contenu Premium' : 'Contenu Réservé'}
        </h3>
        <p class="text-gray-600">
          {message}
        </p>
      </div>

      <!-- Benefits -->
      {!isLoggedIn && (
        <div class="bg-gray-50 rounded-lg p-4 space-y-2 text-sm">
          <p class="font-medium">Avec un compte La Déraison :</p>
          <ul class="space-y-1 text-gray-600">
            <li>✓ Accès à tous les articles</li>
            <li>✓ Votre espace personnel</li>
            <li>✓ Pas de publicités</li>
          </ul>
        </div>
      )}

      {isPaidRequired && isLoggedIn && (
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 text-sm text-amber-900">
          Vous êtes connecté en tant qu'abonné gratuit. Passez à l'abonnement premium pour accéder à ce contenu.
        </div>
      )}

      <!-- CTA Button -->
      <a
        href={ctaLink}
        class="inline-block px-6 py-3 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition"
      >
        {ctaText}
      </a>

      <!-- Secondary link -->
      <p class="text-sm text-gray-600">
        {!isLoggedIn && (
          <>
            Vous avez un compte?{' '}
            <a href={`/connexion?next=${encodeURIComponent(Astro.url.pathname)}`} class="text-black font-medium hover:underline">
              Connectez-vous
            </a>
          </>
        )}
        {isLoggedIn && isPaidRequired && (
          <>
            Questions sur les tarifs?{' '}
            <a href="/abonnement" class="text-black font-medium hover:underline">
              Voir les plans
            </a>
          </>
        )}
      </p>
    </div>
  </div>
</div>

<style>
  /* Ensure overlay is properly positioned */
  :global(.access-gate-container) {
    position: relative;
  }
</style>
