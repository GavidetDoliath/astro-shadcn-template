---
import Layout from '@/layouts/Layout.astro';
import { LoginForm } from '@/components/auth/LoginForm';

// Redirect if already logged in
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/compte');
}

const redirectTo = Astro.url.searchParams.get('next') || '/compte';
const reason = Astro.url.searchParams.get('reason');

const meta = {
  title: 'Connexion',
  description: 'Connectez-vous à votre compte La Déraison',
};
---

<Layout {...meta}>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <section class="space-y-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-bold">Connexion</h1>
        <p class="text-lg text-gray-600">
          Connectez-vous à votre compte pour accéder à votre espace personnel.
        </p>
      </div>

      {reason === 'unauthorized' && (
        <div class="flex gap-3 p-4 bg-amber-50 border border-amber-200 rounded-lg">
          <div class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5">⚠️</div>
          <p class="text-sm text-amber-800">
            Vous devez être connecté pour accéder à cette page.
          </p>
        </div>
      )}

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-8">
        <LoginForm client:load redirectTo={redirectTo} />
      </div>

      <div class="space-y-4 text-center">
        <p class="text-gray-600">
          <a href="/newsletter" class="text-black font-medium hover:underline">
            Pas encore abonné à la newsletter?
          </a>
        </p>
      </div>
    </section>
  </main>
</Layout>
