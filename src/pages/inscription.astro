---
import Layout from '@/layouts/Layout.astro';
import { SignupForm } from '@/components/auth/SignupForm';

// Redirect if already logged in
const user = Astro.locals.user;
if (user) {
  return Astro.redirect('/compte');
}

const meta = {
  title: 'Inscription',
  description: 'Créez votre compte La Déraison',
};
---

<Layout {...meta}>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <section class="space-y-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-bold">Créer un compte</h1>
        <p class="text-lg text-gray-600">
          Inscrivez-vous pour accéder à votre espace personnel et gérer votre abonnement.
        </p>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-8">
        <SignupForm client:load />
      </div>

      <div class="space-y-4 text-center text-sm text-gray-600">
        <p>
          En vous inscrivant, vous acceptez nos conditions d'utilisation et notre politique de confidentialité.
        </p>
      </div>
    </section>
  </main>
</Layout>
