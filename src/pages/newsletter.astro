---
import Layout from '@/layouts/Layout.astro';
import { NewsletterForm } from '@/components/auth/NewsletterForm';

const meta = {
  title: 'Abonnement à la Newsletter',
  description: 'Abonnez-vous à la newsletter de La Déraison pour recevoir nos dernières publications.',
};
---

<Layout {...meta}>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <section class="space-y-8">
      <div class="space-y-4">
        <h1 class="text-4xl font-bold">Abonnement à la Newsletter</h1>
        <p class="text-lg text-gray-600">
          Recevez nos dernières publications directement dans votre boîte mail. Pas de spam, juste nos meilleures pensées.
        </p>
      </div>

      <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 space-y-6">
        <div class="space-y-2">
          <h2 class="text-xl font-semibold">S'abonner à la newsletter</h2>
          <p class="text-gray-600">
            Entrez votre adresse e-mail pour recevoir un lien de confirmation.
          </p>
        </div>

        <NewsletterForm client:load />

        <div class="space-y-3 text-sm text-gray-600">
          <p>✓ Confirmation par e-mail double opt-in</p>
          <p>✓ Désinscription facile à tout moment</p>
          <p>✓ Pas de partage de données avec des tiers</p>
        </div>
      </div>

      <div class="space-y-4">
        <h2 class="text-xl font-semibold">À propos de La Déraison</h2>
        <p class="text-gray-600">
          La Déraison est une publication d'essais, de critiques et de réflexions sur l'actualité et la culture.
          Nos auteurs explorent les sujets sans tabou, toujours avec rigueur et nuance.
        </p>
        <p class="text-gray-600">
          Rejoignez notre communauté de lecteurs passionnés et ne manquez aucune publication.
        </p>
      </div>
    </section>
  </main>
</Layout>
