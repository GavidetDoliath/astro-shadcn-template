---
export const prerender = false;

import '@/styles/global.css';

// If already authenticated, skip the login page
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/admin');
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion · Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="login-container">
      <div class="login-box">
        <h1>Admin</h1>
        <form id="login-form">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required />
          </div>

          <div class="form-group">
            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="password" required />
          </div>

          <div id="error-message" class="error-message" style="display: none;"></div>

          <button type="submit" id="submit-btn" class="submit-btn">Se connecter</button>
        </form>
      </div>
    </div>

    <style is:global>
      .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background-color: var(--fond);
        color: var(--encre);
      }

      .login-box {
        width: 100%;
        max-width: 400px;
        padding: 2rem;
        background-color: var(--parchemin);
        border: 1px solid var(--encre);
        border-radius: 0.25rem;
      }

      .login-box h1 {
        margin-bottom: 2rem;
        text-align: center;
        font-size: 2rem;
      }

      .form-group {
        margin-bottom: 1.5rem;
        display: flex;
        flex-direction: column;
      }

      .form-group label {
        margin-bottom: 0.5rem;
        font-weight: 500;
      }

      .form-group input {
        padding: 0.75rem;
        border: 1px solid var(--encre);
        border-radius: 0.25rem;
        background-color: var(--fond);
        color: var(--encre);
        font-family: inherit;
      }

      .form-group input:focus {
        outline: none;
        border-color: var(--sang);
        box-shadow: 0 0 0 2px rgba(255, 0, 0, 0.1);
      }

      .error-message {
        margin-bottom: 1rem;
        padding: 0.75rem;
        background-color: #fee;
        border: 1px solid #f99;
        border-radius: 0.25rem;
        color: #c00;
        font-size: 0.875rem;
      }

      .submit-btn {
        width: 100%;
        padding: 0.75rem;
        background-color: var(--encre);
        color: var(--fond);
        border: none;
        border-radius: 0.25rem;
        cursor: pointer;
        font-weight: 600;
        font-size: 1rem;
      }

      .submit-btn:hover:not(:disabled) {
        background-color: var(--sang);
      }

      .submit-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
      }
    </style>

    <script>
      document.getElementById('login-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const email = (document.getElementById('email') as HTMLInputElement).value;
        const password = (document.getElementById('password') as HTMLInputElement).value;
        const errorMsg = document.getElementById('error-message')!;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

        errorMsg.style.display = 'none';
        submitBtn.disabled = true;

        try {
          const res = await fetch('/api/admin/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password }),
          });

          if (res.ok) {
            window.location.href = '/admin';
          } else {
            const data = (await res.json()) as { error?: string };
            errorMsg.textContent = data.error || 'Erreur de connexion';
            errorMsg.style.display = 'block';
            submitBtn.disabled = false;
          }
        } catch (err) {
          errorMsg.textContent = 'Erreur réseau';
          errorMsg.style.display = 'block';
          submitBtn.disabled = false;
        }
      });
    </script>
  </body>
</html>
