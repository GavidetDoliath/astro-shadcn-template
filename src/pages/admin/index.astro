---
export const prerender = false;
import { AdminDashboard } from '@/components/admin/AdminDashboard';
import '@/styles/global.css';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin · Articles</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body class="bg-background text-foreground">
    <div class="min-h-screen">
      <!-- Navigation -->
      <nav class="border-b border-border bg-card">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
          <h1 class="text-2xl font-bold">La Déraison Admin</h1>
          <div class="flex gap-4">
            <a href="/" class="hover:text-muted-foreground transition-colors">← Retour au site</a>
            <form method="POST" action="/api/admin/auth/logout" id="logout-form" style="display:inline">
              <button type="submit" class="text-destructive hover:text-destructive/80 transition-colors">Déconnexion</button>
            </form>
          </div>
        </div>
      </nav>

      <!-- Main Content -->
      <div class="mx-auto max-w-6xl px-6 py-8">
        <AdminDashboard client:load />
      </div>
    </div>
  </body>
</html>
