---
export const prerender = false;

import { getAuthenticatedUser, hasRole } from '@/lib/auth';
import { createClient } from '@supabase/supabase-js';

// Check authentication
const accessToken = Astro.cookies.get('sb-access-token')?.value;
const user = await getAuthenticatedUser(accessToken);

if (!user || !hasRole(user, 'admin', 'redacteur')) {
  return Astro.redirect('/admin/login');
}

// Get article ID from URL
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin');
}

// Fetch article
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseAnonKey, {
  auth: { persistSession: false },
  headers: { Authorization: `Bearer ${accessToken}` },
});

const { data: article, error } = await supabase.from('articles').select('*').eq('id', id).single();

if (error || !article) {
  return Astro.redirect('/admin');
}

// Check permissions: redacteur can only edit their own, admins can edit any
const isOwnArticle = article.author_id === user.id;
if (user.role === 'redacteur' && !isOwnArticle) {
  return Astro.redirect('/admin');
}
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Éditer Article · Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-950">
      <div class="mx-auto max-w-6xl p-6">
        <!-- Header -->
        <div class="mb-8 flex items-center justify-between">
          <div>
            <h1 class="text-3xl font-bold">Éditer l'article</h1>
            <p class="mt-2 text-gray-600 dark:text-gray-400">{article.title}</p>
          </div>
          <a href="/admin" class="rounded-lg bg-gray-300 px-4 py-2 hover:bg-gray-400 dark:bg-gray-700 dark:hover:bg-gray-600">
            ← Retour
          </a>
        </div>

        <!-- Form Container -->
        <div class="rounded-lg bg-white p-8 shadow-lg dark:bg-gray-900">
          <form id="article-form" class="space-y-6">
            <!-- Row 1: Title and Author -->
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              <div>
                <label for="title" class="block text-sm font-medium">
                  Titre *
                </label>
                <input
                  type="text"
                  id="title"
                  name="title"
                  value={article.title}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                  required
                />
              </div>
              <div>
                <label for="author" class="block text-sm font-medium">
                  Auteur
                </label>
                <input
                  type="text"
                  id="author"
                  name="author"
                  value={article.author || ''}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                />
              </div>
            </div>

            <!-- Row 2: Slug and Date -->
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              <div>
                <label for="slug" class="block text-sm font-medium">
                  Slug (URL) *
                </label>
                <input
                  type="text"
                  id="slug"
                  name="slug"
                  value={article.slug}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                  required
                />
              </div>
              <div>
                <label for="date" class="block text-sm font-medium">
                  Date de publication *
                </label>
                <input
                  type="date"
                  id="date"
                  name="date"
                  value={article.date}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                  required
                />
              </div>
            </div>

            <!-- Row 3: Category and Access Level -->
            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
              <div>
                <label for="category" class="block text-sm font-medium">
                  Catégorie *
                </label>
                <select
                  id="category"
                  name="category"
                  value={article.category}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                  required
                >
                  <option value="lettre">Lettre</option>
                  <option value="pamphlet">Pamphlet</option>
                  <option value="fosse">Fosse</option>
                </select>
              </div>
              <div>
                <label for="accessLevel" class="block text-sm font-medium">
                  Accès *
                </label>
                <select
                  id="accessLevel"
                  name="accessLevel"
                  value={article.access_level}
                  class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                  required
                >
                  <option value="public">Public</option>
                  <option value="subscriber_free">Abonné gratuit</option>
                  <option value="subscriber_paid">Abonné payant</option>
                </select>
              </div>
            </div>

            <!-- Excerpt -->
            <div>
              <label for="excerpt" class="block text-sm font-medium">
                Extrait (résumé court)
              </label>
              <textarea
                id="excerpt"
                name="excerpt"
                rows="3"
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                placeholder="Résumé de l'article"
              >{article.excerpt}</textarea>
            </div>

            <!-- Image URL -->
            <div>
              <label for="image" class="block text-sm font-medium">
                URL Image
              </label>
              <input
                type="url"
                id="image"
                name="image"
                value={article.image || ''}
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                placeholder="https://..."
              />
            </div>

            <!-- LinkedIn URL -->
            <div>
              <label for="linkedinUrl" class="block text-sm font-medium">
                URL LinkedIn (source)
              </label>
              <input
                type="url"
                id="linkedinUrl"
                name="linkedinUrl"
                value={article.linkedinUrl || ''}
                class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 dark:border-gray-700 dark:bg-gray-950"
                placeholder="https://linkedin.com/pulse/..."
              />
            </div>

            <!-- Rich Text Editor -->
            <div>
              <label class="block text-sm font-medium mb-2">Contenu de l'article *</label>
              <div id="editor-container"></div>
              <input type="hidden" id="content" name="content" value={article.content} />
            </div>

            <!-- Checkboxes -->
            <div class="space-y-3">
              <label class="flex items-center gap-2">
                <input
                  type="checkbox"
                  name="featured"
                  checked={article.featured}
                  class="h-4 w-4 rounded border-gray-300"
                />
                <span class="text-sm font-medium">En avant (featured)</span>
              </label>
              <label class="flex items-center gap-2">
                <input
                  type="checkbox"
                  name="published"
                  checked={article.published}
                  class="h-4 w-4 rounded border-gray-300"
                />
                <span class="text-sm font-medium">Publié</span>
              </label>
            </div>

            <!-- Error Message -->
            <div id="error-message" class="hidden rounded-lg bg-red-50 p-4 text-sm text-red-800 dark:bg-red-900/20 dark:text-red-300">
            </div>

            <!-- Submit Buttons -->
            <div class="flex justify-end gap-3">
              <a
                href="/admin"
                class="rounded-lg border border-gray-300 px-6 py-2 font-medium hover:bg-gray-50 dark:border-gray-700 dark:hover:bg-gray-900"
              >
                Annuler
              </a>
              <button
                type="submit"
                class="rounded-lg bg-blue-600 px-6 py-2 font-medium text-white hover:bg-blue-700 disabled:opacity-50"
              >
                Enregistrer
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script define:vars={{ articleId: article.id }}>
      document.getElementById('article-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(e.target);
        const data = {
          title: formData.get('title'),
          excerpt: formData.get('excerpt'),
          content: formData.get('content'),
          date: formData.get('date'),
          category: formData.get('category'),
          image: formData.get('image'),
          slug: formData.get('slug'),
          author: formData.get('author'),
          linkedinUrl: formData.get('linkedinUrl'),
          featured: formData.get('featured') === 'on',
          published: formData.get('published') === 'on',
          accessLevel: formData.get('accessLevel'),
        };

        if (!data.title) {
          showError('Le titre est requis');
          return;
        }
        if (!data.slug) {
          showError('Le slug est requis');
          return;
        }
        if (!data.content) {
          showError('Le contenu est requis');
          return;
        }

        try {
          const response = await fetch(`/api/admin/articles/${articleId}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data),
          });

          if (response.ok) {
            window.location.href = '/admin';
          } else {
            const error = await response.json();
            showError(error.error || 'Erreur lors de la modification');
          }
        } catch (err) {
          showError('Erreur réseau');
        }
      });

      function showError(message) {
        const errorEl = document.getElementById('error-message');
        errorEl.textContent = message;
        errorEl.classList.remove('hidden');
      }
    </script>
  </body>
</html>
