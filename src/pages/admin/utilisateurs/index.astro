---
import { getServerSupabase } from '@/lib/supabase';
import AdminLayout from '@/layouts/AdminLayout.astro';
import UsersList from '@/components/admin/UsersList';

export const prerender = false; // SSR required for auth

const user = Astro.locals.user;

// Redirect if not authenticated as admin
if (!user || user.role !== 'admin') {
  return Astro.redirect('/admin/login');
}

// Fetch all users
const supabase = getServerSupabase();

// Get users from auth
const { data: { users: authUsers }, error: usersError } = await supabase.auth.admin.listUsers();

if (usersError) {
  console.error('Error fetching users:', usersError);
}

// Get profiles
const { data: profiles, error: profilesError } = await supabase
  .from('profiles')
  .select('*');

if (profilesError) {
  console.error('Error fetching profiles:', profilesError);
}

// Combine data
const users = (authUsers || []).map(authUser => {
  const profile = (profiles || []).find(p => p.id === authUser.id);
  return {
    id: authUser.id,
    email: authUser.email,
    created_at: authUser.created_at,
    confirmed_at: authUser.confirmed_at,
    role: profile?.role || 'subscriber_free',
    display_name: profile?.display_name,
    stripe_subscription_status: profile?.stripe_subscription_status,
  };
});

const title = 'Utilisateurs';
---

<AdminLayout title={title}>
  <div class="space-y-4">
    <!-- Header -->
    <div>
      <h1>Gestion des utilisateurs</h1>
      <p style="color: var(--gris-presse); font-size: 0.9rem;">
        Créez, modifiez et supprimez les comptes utilisateurs
      </p>
    </div>

    <!-- Stats -->
    <div class="stats-row">
      <div>
        <div style="color: var(--gris-presse); font-size: 0.85rem;">Total</div>
        <div style="font-size: 1.5rem; font-weight: bold;">{users.length}</div>
      </div>
      <div>
        <div style="color: var(--gris-presse); font-size: 0.85rem;">Admins</div>
        <div style="font-size: 1.5rem; font-weight: bold;">
          {users.filter(u => u.role === 'admin').length}
        </div>
      </div>
      <div>
        <div style="color: var(--gris-presse); font-size: 0.85rem;">Rédacteurs</div>
        <div style="font-size: 1.5rem; font-weight: bold;">
          {users.filter(u => u.role === 'redacteur').length}
        </div>
      </div>
      <div>
        <div style="color: var(--gris-presse); font-size: 0.85rem;">Abonnés</div>
        <div style="font-size: 1.5rem; font-weight: bold;">
          {users.filter(u => u.role?.includes('subscriber')).length}
        </div>
      </div>
    </div>

    <!-- Users List Component -->
    <UsersList client:load initialUsers={users} />
  </div>
</AdminLayout>
