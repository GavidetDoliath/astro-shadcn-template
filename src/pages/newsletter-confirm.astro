---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import { createClient } from '@supabase/supabase-js';

const meta = {
  title: 'Confirmation d\'abonnement',
  description: 'Confirmez votre abonnement à la newsletter de La Déraison',
};

// Get confirmation token from URL
const token = Astro.url.searchParams.get('token');
let confirmationStatus: 'loading' | 'success' | 'error' | 'expired' = 'loading';
let confirmationMessage = '';
let confirmedEmail = '';

if (token) {
  // Verify the token by calling the API
  try {
    const response = await fetch(
      `${Astro.url.origin}/api/newsletter/confirm?token=${encodeURIComponent(token)}`
    );
    const data = await response.json() as Record<string, any>;

    if (response.ok) {
      confirmationStatus = 'success';
      confirmationMessage = data.message || 'Votre adresse e-mail a été confirmée avec succès!';
      confirmedEmail = data.email || '';
    } else if (response.status === 410) {
      confirmationStatus = 'expired';
      confirmationMessage = data.error || 'Ce lien de confirmation a expiré. Veuillez vous réabonner.';
    } else {
      confirmationStatus = 'error';
      confirmationMessage = data.error || 'Nous n\'avons pas pu confirmer votre adresse e-mail.';
    }
  } catch (err) {
    console.error('Confirmation error:', err);
    confirmationStatus = 'error';
    confirmationMessage = 'Une erreur est survenue lors de la confirmation.';
  }
} else {
  confirmationStatus = 'error';
  confirmationMessage = 'Aucun token de confirmation fourni.';
}
---

<Layout {...meta}>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <section class="space-y-8">
      {confirmationStatus === 'success' && (
        <div class="space-y-4">
          <div class="bg-green-50 border border-green-200 rounded-lg p-8 space-y-4">
            <div class="flex items-center gap-3">
              <div class="h-12 w-12 bg-green-500 rounded-full flex items-center justify-center text-white text-xl">
                ✓
              </div>
              <h1 class="text-3xl font-bold text-green-900">Abonnement confirmé!</h1>
            </div>
            <p class="text-lg text-green-800">
              {confirmationMessage}
            </p>
            {confirmedEmail && (
              <p class="text-sm text-green-700">
                Adresse: <strong>{confirmedEmail}</strong>
              </p>
            )}
            <p class="text-gray-600 mt-6">
              Vous recevrez bientôt nos dernières publications. Merci de votre confiance!
            </p>
          </div>

          <div class="space-y-3">
            <a
              href="/"
              class="inline-block px-6 py-3 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition"
            >
              ← Retour à l'accueil
            </a>
          </div>
        </div>
      )}

      {(confirmationStatus === 'error' || confirmationStatus === 'expired') && (
        <div class="space-y-4">
          <div class="bg-red-50 border border-red-200 rounded-lg p-8 space-y-4">
            <div class="flex items-center gap-3">
              <div class="h-12 w-12 bg-red-500 rounded-full flex items-center justify-center text-white text-xl">
                ✕
              </div>
              <h1 class="text-3xl font-bold text-red-900">
                {confirmationStatus === 'expired' ? 'Lien expiré' : 'Erreur de confirmation'}
              </h1>
            </div>
            <p class="text-lg text-red-800">{confirmationMessage}</p>
          </div>

          <div class="space-y-3">
            <a
              href="/newsletter"
              class="inline-block px-6 py-3 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition"
            >
              Réessayer
            </a>
            <a href="/" class="inline-block px-6 py-3 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition ml-2">
              Retour à l'accueil
            </a>
          </div>
        </div>
      )}
    </section>
  </main>
</Layout>
