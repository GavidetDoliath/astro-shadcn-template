---
import Layout from '@/layouts/Layout.astro';
import { getServerSupabase } from '@/lib/supabase';

export const prerender = false; // SSR required for auth

const user = Astro.locals.user;

// Redirect if not authenticated
if (!user) {
  return Astro.redirect('/connexion?next=/compte/abonnement');
}

// Fetch profile for subscription info
const supabase = getServerSupabase();
const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

const success = Astro.url.searchParams.get('success') === 'true';

const meta = {
  title: 'Mon abonnement',
  description: 'Gérez votre abonnement La Déraison',
};

const formatDate = (dateStr: string | null) => {
  if (!dateStr) return null;
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};
---

<Layout {...meta}>
  <main class="max-w-2xl mx-auto px-4 py-12">
    <section class="space-y-8">
      <!-- Header -->
      <div class="space-y-2">
        <h1 class="text-4xl font-bold">Mon abonnement</h1>
        <p class="text-gray-600">Gérez votre souscription</p>
      </div>

      {success && (
        <div class="flex gap-3 p-4 bg-green-50 border border-green-200 rounded-lg">
          <div class="h-5 w-5 text-green-600 flex-shrink-0 mt-0.5">✓</div>
          <div>
            <p class="font-medium text-green-900">Paiement reçu!</p>
            <p class="text-sm text-green-800">Merci d'être devenu abonné premium.</p>
          </div>
        </div>
      )}

      <!-- Subscription Status -->
      <div class="bg-gray-50 border border-gray-200 rounded-lg p-8 space-y-6">
        <div>
          <p class="text-sm text-gray-600">Statut</p>
          <div class="flex items-center gap-2 mt-2">
            {profile?.role === 'subscriber_paid' ? (
              <>
                <span class="h-3 w-3 bg-green-500 rounded-full"></span>
                <p class="text-lg font-semibold text-green-700">Abonné Premium</p>
              </>
            ) : (
              <>
                <span class="h-3 w-3 bg-gray-400 rounded-full"></span>
                <p class="text-lg font-semibold text-gray-700">Abonné Gratuit</p>
              </>
            )}
          </div>
        </div>

        {profile?.role === 'subscriber_paid' && (
          <>
            <div>
              <p class="text-sm text-gray-600">Plan</p>
              <p class="text-lg font-semibold mt-1">Premium - 5€/mois</p>
            </div>

            {profile?.subscription_current_period_end && (
              <div>
                <p class="text-sm text-gray-600">Renouvellement</p>
                <p class="text-lg font-semibold mt-1">
                  {formatDate(profile.subscription_current_period_end)}
                </p>
              </div>
            )}

            {profile?.stripe_subscription_status && (
              <div>
                <p class="text-sm text-gray-600">État de la souscription</p>
                <p class="text-lg font-semibold mt-1 capitalize">
                  {profile.stripe_subscription_status === 'active' && '✓ Actif'}
                  {profile.stripe_subscription_status === 'past_due' && '⚠️ En retard'}
                  {profile.stripe_subscription_status === 'trialing' && '🔄 Période d\'essai'}
                  {profile.stripe_subscription_status === 'canceled' && '❌ Annulé'}
                </p>
              </div>
            )}
          </>
        )}

        {profile?.role === 'subscriber_paid' ? (
          <button
            onclick="openPortal()"
            class="px-6 py-2 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition"
          >
            Gérer mon abonnement
          </button>
        ) : (
          <a
            href="/abonnement"
            class="inline-block px-6 py-2 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition"
          >
            Passer à Premium (5€/mois)
          </a>
        )}
      </div>

      <!-- Features -->
      <div class="space-y-4">
        <h2 class="text-2xl font-bold">Avantages Premium</h2>
        <div class="grid gap-4">
          <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
            <span class="text-2xl">📰</span>
            <div>
              <h3 class="font-semibold">Articles exclusifs</h3>
              <p class="text-sm text-gray-600">Accédez à tout notre contenu premium</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
            <span class="text-2xl">⏰</span>
            <div>
              <h3 class="font-semibold">Accès prioritaire</h3>
              <p class="text-sm text-gray-600">Lisez les articles avant leur publication publique</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
            <span class="text-2xl">🙏</span>
            <div>
              <h3 class="font-semibold">Soutien direct</h3>
              <p class="text-sm text-gray-600">Soutenez directement la création indépendante</p>
            </div>
          </div>
          <div class="flex gap-4 p-4 bg-gray-50 rounded-lg">
            <span class="text-2xl">🎯</span>
            <div>
              <h3 class="font-semibold">Pas de publicités</h3>
              <p class="text-sm text-gray-600">Profitez d'une expérience sans distractions</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Support -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 space-y-3">
        <p class="font-semibold text-blue-900">Besoin d'aide?</p>
        <p class="text-sm text-blue-800">
          Pour toute question sur votre abonnement, veuillez nous contacter à:
        </p>
        <a href="mailto:support@example.com" class="text-blue-600 font-medium hover:underline">
          support@example.com
        </a>
      </div>
    </section>
  </main>

  <script>
    async function openPortal() {
      try {
        const res = await fetch('/api/stripe/portal', { method: 'POST' });
        const data = await res.json() as { url?: string; error?: string };

        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Erreur: ' + (data.error || 'Impossible d\'ouvrir le portail'));
        }
      } catch (err) {
        alert('Erreur réseau');
      }
    }

    // Expose function globally
    (window as any).openPortal = openPortal;
  </script>
</Layout>
