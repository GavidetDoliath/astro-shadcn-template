---
import Layout from '@/layouts/Layout.astro';
import { getServerSupabase } from '@/lib/supabase';

export const prerender = false; // SSR required for auth

const user = Astro.locals.user;

// Redirect to login if not authenticated
if (!user) {
  return Astro.redirect('/connexion?next=/compte');
}

// Fetch user profile details
const supabase = getServerSupabase();
const { data: profile } = await supabase
  .from('profiles')
  .select('*')
  .eq('id', user.id)
  .single();

const meta = {
  title: 'Mon compte',
  description: 'Gérez votre compte et votre abonnement',
};
---

<Layout {...meta}>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <section class="space-y-8">
      <!-- Header -->
      <div class="flex items-center justify-between">
        <div class="space-y-2">
          <h1 class="text-4xl font-bold">Mon compte</h1>
          <p class="text-lg text-gray-600">
            Bienvenue, <strong>{profile?.display_name || user.email}</strong>
          </p>
        </div>
        <form action="/api/auth/logout" method="POST">
          <button
            type="submit"
            class="px-6 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition"
          >
            Déconnexion
          </button>
        </form>
      </div>

      <!-- Main Content -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <!-- Sidebar -->
        <aside class="md:col-span-1">
          <nav class="space-y-2 sticky top-4">
            <a
              href="#profil"
              class="block px-4 py-2 rounded-lg bg-black text-white font-medium"
            >
              Profil
            </a>
            <a
              href="#abonnement"
              class="block px-4 py-2 rounded-lg hover:bg-gray-100 transition"
            >
              Abonnement
            </a>
            <a
              href="#securite"
              class="block px-4 py-2 rounded-lg hover:bg-gray-100 transition"
            >
              Sécurité
            </a>
          </nav>
        </aside>

        <!-- Main Content -->
        <main class="md:col-span-2 space-y-8">
          <!-- Profil Section -->
          <section id="profil" class="space-y-4">
            <h2 class="text-2xl font-bold">Profil</h2>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 space-y-4">
              <div>
                <p class="text-sm text-gray-600">Email</p>
                <p class="text-lg font-medium">{user.email}</p>
              </div>
              <div>
                <p class="text-sm text-gray-600">Nom complet</p>
                <p class="text-lg font-medium">{profile?.display_name || 'Non défini'}</p>
              </div>
              <div>
                <p class="text-sm text-gray-600">Rôle</p>
                <p class="text-lg font-medium capitalize">
                  {profile?.role === 'subscriber_free' ? 'Abonné gratuit' :
                   profile?.role === 'subscriber_paid' ? 'Abonné payant' :
                   profile?.role}
                </p>
              </div>
              <button
                class="px-4 py-2 bg-black text-white rounded-lg font-medium hover:bg-gray-800 transition disabled:opacity-50"
                disabled
              >
                Modifier le profil (bientôt disponible)
              </button>
            </div>
          </section>

          <!-- Abonnement Section -->
          <section id="abonnement" class="space-y-4">
            <h2 class="text-2xl font-bold">Abonnement</h2>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 space-y-4">
              <div>
                <p class="text-sm text-gray-600">Statut</p>
                <div class="flex items-center gap-2 mt-1">
                  <span class="h-3 w-3 bg-green-500 rounded-full"></span>
                  <p class="text-lg font-medium">
                    {profile?.role === 'subscriber_paid' ? 'Abonné payant (actif)' :
                     'Abonné gratuit'}
                  </p>
                </div>
              </div>
              {profile?.subscription_current_period_end && (
                <div>
                  <p class="text-sm text-gray-600">Renouvellement</p>
                  <p class="text-lg font-medium">
                    {new Date(profile.subscription_current_period_end).toLocaleDateString('fr-FR')}
                  </p>
                </div>
              )}
              <button
                class="px-4 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-100 transition disabled:opacity-50"
                disabled
              >
                Gérer l'abonnement (bientôt disponible)
              </button>
            </div>
          </section>

          <!-- Sécurité Section -->
          <section id="securite" class="space-y-4">
            <h2 class="text-2xl font-bold">Sécurité</h2>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-6 space-y-4">
              <p class="text-gray-600">
                Gérez les paramètres de sécurité de votre compte.
              </p>
              <button
                class="px-4 py-2 border border-gray-300 rounded-lg font-medium hover:bg-gray-100 transition disabled:opacity-50"
                disabled
              >
                Changer le mot de passe (bientôt disponible)
              </button>
            </div>
          </section>
        </main>
      </div>
    </section>
  </main>
</Layout>
