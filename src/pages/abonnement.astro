---
import Layout from '@/layouts/Layout.astro';

const user = Astro.locals.user;
const cancelled = Astro.url.searchParams.get('cancelled') === 'true';

const meta = {
  title: 'Abonnement Premium',
  description: 'Accédez à tout notre contenu exclusif avec un abonnement premium',
};
---

<Layout {...meta}>
  <main class="max-w-4xl mx-auto px-4 py-12">
    <section class="space-y-12">
      <!-- Header -->
      <div class="text-center space-y-4">
        <h1 class="text-5xl font-bold">Abonnement Premium</h1>
        <p class="text-xl text-gray-600">
          Accédez à tout notre contenu exclusif et soutenez la création indépendante
        </p>
      </div>

      {cancelled && (
        <div class="flex gap-3 p-4 bg-amber-50 border border-amber-200 rounded-lg">
          <div class="h-5 w-5 text-amber-600 flex-shrink-0 mt-0.5">⚠️</div>
          <p class="text-sm text-amber-800">
            Votre session d'achat a été annulée. N'hésitez pas à réessayer.
          </p>
        </div>
      )}

      <!-- Pricing Cards -->
      <div class="grid md:grid-cols-2 gap-8 mt-12">
        <!-- Free Plan -->
        <div class="border border-gray-200 rounded-lg p-8 space-y-6">
          <div>
            <h2 class="text-2xl font-bold">Abonné Gratuit</h2>
            <p class="text-gray-600 text-sm">Pour commencer</p>
          </div>

          <div>
            <div class="text-3xl font-bold">Gratuit</div>
            <p class="text-gray-600 text-sm">Pour toujours</p>
          </div>

          <ul class="space-y-3 text-sm">
            <li class="flex gap-2">
              <span class="text-green-600">✓</span>
              <span>Accès aux articles publics</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-600">✓</span>
              <span>Newsletter hebdomadaire</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-600">✓</span>
              <span>Accès aux articles gratuits</span>
            </li>
          </ul>

          {!user ? (
            <a
              href="/inscription"
              class="block text-center px-6 py-3 border border-gray-300 rounded-lg font-medium hover:bg-gray-50 transition"
            >
              Créer un compte
            </a>
          ) : (
            <div class="text-center text-sm text-gray-600">
              ✓ Vous êtes inscrit
            </div>
          )}
        </div>

        <!-- Premium Plan -->
        <div class="border-2 border-black rounded-lg p-8 space-y-6 bg-black text-white relative">
          <div class="absolute top-0 right-0 bg-black text-white px-4 py-1 text-xs font-bold">
            POPULAIRE
          </div>

          <div>
            <h2 class="text-2xl font-bold">Abonné Premium</h2>
            <p class="text-gray-300 text-sm">Pour les passionnés</p>
          </div>

          <div>
            <div class="text-4xl font-bold">5€</div>
            <p class="text-gray-300 text-sm">par mois, résiliable à tout moment</p>
          </div>

          <ul class="space-y-3 text-sm">
            <li class="flex gap-2">
              <span class="text-green-400">✓</span>
              <span>Tout du plan gratuit</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-400">✓</span>
              <span>Accès à tous les articles exclusifs</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-400">✓</span>
              <span>Contenu premium sans publicités</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-400">✓</span>
              <span>Accès antérieur à la publication</span>
            </li>
            <li class="flex gap-2">
              <span class="text-green-400">✓</span>
              <span>Soutien direct des auteurs</span>
            </li>
          </ul>

          {!user ? (
            <a
              href="/inscription"
              class="block text-center px-6 py-3 bg-white text-black rounded-lg font-bold hover:bg-gray-100 transition"
            >
              S'inscrire pour 5€/mois
            </a>
          ) : user.role === 'subscriber_paid' ? (
            <div class="text-center text-sm text-green-400">
              ✓ Vous êtes abonné
            </div>
          ) : (
            <button
              onclick="startCheckout()"
              class="w-full px-6 py-3 bg-white text-black rounded-lg font-bold hover:bg-gray-100 transition"
            >
              Passer à Premium (5€/mois)
            </button>
          )}
        </div>
      </div>

      <!-- FAQ -->
      <div class="space-y-6 mt-12 border-t pt-12">
        <h2 class="text-3xl font-bold">Questions fréquentes</h2>

        <div class="space-y-4">
          <div class="space-y-2">
            <h3 class="font-bold">Puis-je annuler mon abonnement?</h3>
            <p class="text-gray-600">
              Oui, vous pouvez annuler à tout moment depuis votre compte. L'accès continue jusqu'à la fin de la période de facturation.
            </p>
          </div>

          <div class="space-y-2">
            <h3 class="font-bold">Quels modes de paiement acceptez-vous?</h3>
            <p class="text-gray-600">
              Nous acceptons toutes les cartes de crédit (Visa, Mastercard, American Express) via Stripe.
            </p>
          </div>

          <div class="space-y-2">
            <h3 class="font-bold">Y a-t-il une période d'essai gratuite?</h3>
            <p class="text-gray-600">
              Non, mais vous pouvez commencer avec un compte gratuit et passer à premium à tout moment.
            </p>
          </div>

          <div class="space-y-2">
            <h3 class="font-bold">Comment puis-je modifier ou annuler?</h3>
            <p class="text-gray-600">
              Connectez-vous à votre compte et allez dans "Mon abonnement" pour gérer votre souscription.
            </p>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <div class="bg-black text-white rounded-lg p-8 text-center space-y-4">
        <h2 class="text-2xl font-bold">Prêt à rejoindre?</h2>
        <p class="text-gray-300">
          Accédez à tout notre contenu exclusif et soutenez la création indépendante
        </p>
        {!user ? (
          <a
            href="/inscription"
            class="inline-block px-8 py-3 bg-white text-black rounded-lg font-bold hover:bg-gray-100 transition"
          >
            Commencer maintenant
          </a>
        ) : user.role === 'subscriber_paid' ? (
          <p class="text-green-400">✓ Merci d'être premium!</p>
        ) : (
          <button
            onclick="startCheckout()"
            class="inline-block px-8 py-3 bg-white text-black rounded-lg font-bold hover:bg-gray-100 transition"
          >
            S'abonner pour 5€/mois
          </button>
        )}
      </div>
    </section>
  </main>

  <script>
    async function startCheckout() {
      try {
        const res = await fetch('/api/stripe/create-checkout', { method: 'POST' });
        const data = await res.json() as { url?: string; error?: string };

        if (data.url) {
          window.location.href = data.url;
        } else {
          alert('Erreur: ' + (data.error || 'Impossible de créer la session'));
        }
      } catch (err) {
        alert('Erreur réseau');
      }
    }

    // Expose function globally for onclick
    (window as any).startCheckout = startCheckout;
  </script>
</Layout>
