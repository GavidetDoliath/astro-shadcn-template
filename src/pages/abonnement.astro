---
// src/pages/abonnement.astro
// Pricing / Subscription page

import Layout from '@/layouts/Layout.astro';

const meta = {
  title: 'La Fosse · Abonnement · La Déraison',
  description: 'Accédez à l\'intégralité de nos publications en vous abonnant à La Fosse',
};
---

<Layout {...meta}>
  <section class="pricing-section">
    <div class="pricing-container">
      <!-- Header -->
      <header class="pricing-header">
        <h1 class="pricing-title">La Fosse</h1>
        <p class="pricing-subtitle">
          Explorez les abysses de la pensée. Accédez à l'intégralité de nos publications avec un abonnement mensuel.
        </p>
      </header>

      <!-- Rule -->
      <div class="pricing-rule" />

      <!-- Pricing Card -->
      <div class="pricing-cards">
        <article class="pricing-card">
          <div class="pricing-card__content">
            <h2 class="pricing-card__title">Abonnement Mensuel</h2>
            <p class="pricing-card__description">
              Accès complet à tous nos articles, avec renouvellement automatique chaque mois.
            </p>

            <div class="pricing-card__price">
              <span class="pricing-card__amount">5€</span>
              <span class="pricing-card__period">/mois</span>
            </div>

            <ul class="pricing-card__features">
              <li>📚 Accès à tous les articles publiés</li>
              <li>📬 Infolettre hebdomadaire</li>
              <li>🔐 Contenu exclusif et en avant-première</li>
              <li>📖 Pas de publicité</li>
              <li>⏸️ Annulation en un clic</li>
            </ul>

            <button
              type="button"
              class="pricing-card__cta"
              id="checkout-button"
              data-stripe="true"
            >
              S'abonner maintenant
            </button>
          </div>

          <p class="pricing-card__note">
            Paiement sécurisé via Stripe. Aucune donnée bancaire stockée sur nos serveurs.
          </p>
        </article>
      </div>

      <!-- FAQ -->
      <section class="pricing-faq">
        <h2 class="pricing-faq__title">Questions fréquentes</h2>

        <div class="pricing-faq__items">
          <details class="pricing-faq__item">
            <summary class="pricing-faq__question">
              Puis-je annuler mon abonnement ?
            </summary>
            <p class="pricing-faq__answer">
              Oui, vous pouvez annuler votre abonnement à tout moment sans préavis. Vous aurez accès aux articles jusqu'à la fin de votre cycle de facturation.
            </p>
          </details>

          <details class="pricing-faq__item">
            <summary class="pricing-faq__question">
              Quels modes de paiement acceptez-vous ?
            </summary>
            <p class="pricing-faq__answer">
              Nous acceptons les cartes bancaires (Visa, Mastercard, American Express) et les portefeuilles numériques via Stripe.
            </p>
          </details>

          <details class="pricing-faq__item">
            <summary class="pricing-faq__question">
              Puis-je avoir un essai gratuit ?
            </summary>
            <p class="pricing-faq__answer">
              Non, il n'y a pas d'essai gratuit. L'abonnement commence immédiatement après la première charge. Vous pouvez néanmoins annuler à tout moment.
            </p>
          </details>

          <details class="pricing-faq__item">
            <summary class="pricing-faq__question">
              Que se passe-t-il si je perds l'accès à mon compte ?
            </summary>
            <p class="pricing-faq__answer">
              Contactez-nous via notre formulaire de support avec l'email associé à votre abonnement, et nous vous aiderons à récupérer l'accès.
            </p>
          </details>
        </div>
      </section>
    </div>
  </section>

  <script is:inline>
    // Handle Stripe checkout button
    const checkoutBtn = document.getElementById('checkout-button');

    if (checkoutBtn) {
      checkoutBtn.addEventListener('click', async () => {
        try {
          const response = await fetch('/api/stripe/checkout', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              userId: 'guest', // Will be handled by server or redirect to login
            }),
          });

          const data = await response.json();

          if (data.error) {
            alert('Erreur : ' + data.error);
            return;
          }

          // Redirect to Stripe checkout
          if (data.url) {
            window.location.href = data.url;
          }
        } catch (error) {
          console.error('Checkout error:', error);
          alert('Erreur lors de la tentative de paiement. Veuillez réessayer.');
        }
      });
    }
  </script>
</Layout>

<style lang="scss">
  .pricing-section {
    min-height: 100vh;
    background: var(--noir);
    padding: clamp(2rem, 6vh, 4rem) clamp(1.5rem, 8vw, 8rem);

    &::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 200px 200px;
      opacity: 0.06;
      mix-blend-mode: overlay;
      pointer-events: none;
      z-index: 0;
    }
  }

  .pricing-container {
    position: relative;
    z-index: 1;
    max-width: 900px;
    margin: 0 auto;
  }

  .pricing-header {
    margin-bottom: 3rem;
  }

  .pricing-title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 0.95;
    color: var(--parchemin);
    margin: 0 0 0.5rem 0;
  }

  .pricing-subtitle {
    font-family: var(--font-body);
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--beige-pali);
    margin: 0;
    max-width: 70ch;
  }

  .pricing-rule {
    width: 3rem;
    height: 2px;
    background: var(--sang);
    margin-bottom: 3rem;
  }

  .pricing-cards {
    display: flex;
    justify-content: center;
    margin-bottom: 4rem;
  }

  .pricing-card {
    background: var(--encre);
    border: 1px solid rgb(192 57 43 / 0.2);
    padding: clamp(2rem, 5vw, 3rem);
    width: 100%;
    max-width: 450px;
    border-radius: 0.5rem;
  }

  .pricing-card__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pricing-card__title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(1.5rem, 3vw, 2rem);
    color: var(--parchemin);
    margin: 0;
  }

  .pricing-card__description {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--beige-pali);
    line-height: 1.6;
    margin: 0;
  }

  .pricing-card__price {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 1.5rem;
    background: var(--noir);
    border-radius: 0.25rem;
  }

  .pricing-card__amount {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--sang);
  }

  .pricing-card__period {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--beige-pali);
    letter-spacing: 0.1em;
  }

  .pricing-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;

    li {
      font-family: var(--font-body);
      font-size: 0.95rem;
      color: var(--beige-pali);
      line-height: 1.5;
      padding-left: 0;

      &::before {
        content: '✓ ';
        color: var(--sang);
        font-weight: bold;
        margin-right: 0.5rem;
      }
    }
  }

  .pricing-card__cta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--noir);
    background: var(--parchemin);
    border: none;
    padding: 1rem 2rem;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    border-radius: 0.5rem;

    &::after {
      content: '';
      position: absolute;
      bottom: -4px;
      right: -4px;
      width: 100%;
      height: 100%;
      border: 1px solid var(--sang);
      transition: transform 0.2s;
      border-radius: 0.5rem;
    }

    &:hover {
      background: var(--sang);
      color: var(--parchemin);

      &::after {
        transform: translate(3px, 3px);
      }
    }
  }

  .pricing-card__note {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--gris-presse);
    text-align: center;
    margin: 1rem 0 0 0;
  }

  .pricing-faq {
    margin-top: 3rem;
  }

  .pricing-faq__title {
    font-family: var(--font-serif);
    font-weight: 900;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    color: var(--parchemin);
    margin: 0 0 2rem 0;
  }

  .pricing-faq__items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pricing-faq__item {
    background: var(--encre);
    border: 1px solid rgb(192 57 43 / 0.2);
    padding: 1.5rem;
    border-radius: 0.5rem;

    &[open] {
      background: var(--encre);
    }
  }

  .pricing-faq__question {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 1.05rem;
    color: var(--parchemin);
    cursor: pointer;
    user-select: none;

    &::before {
      content: '▶ ';
      display: inline-block;
      margin-right: 0.5rem;
      transition: transform 0.2s;
    }
  }

  .pricing-faq__item[open] .pricing-faq__question::before {
    transform: rotate(90deg);
  }

  .pricing-faq__answer {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--beige-pali);
    line-height: 1.6;
    margin: 1rem 0 0 1.5rem;
  }

  @media (max-width: 640px) {
    .pricing-section {
      padding: 1.5rem 1rem;
    }

    .pricing-title {
      font-size: clamp(2rem, 5vw, 2.5rem);
    }

    .pricing-card {
      padding: 1.5rem;
    }

    .pricing-faq__answer {
      margin-left: 1rem;
    }
  }
</style>
