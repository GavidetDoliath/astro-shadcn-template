---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} · Admin` : 'Admin'}</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="min-h-screen bg-gray-50 dark:bg-gray-950">
      <div class="mx-auto max-w-6xl p-6">
        <slot />
      </div>
    </div>
  </body>
</html>

<style is:global>
  body {
    @apply bg-gray-50 dark:bg-gray-950;
  }

  /* TipTap Editor Styles */
  .ProseMirror {
    @apply prose prose-sm max-w-none dark:prose-invert;
  }

  .ProseMirror p {
    @apply my-2;
  }

  .ProseMirror h1 {
    @apply my-4 text-2xl font-bold;
  }

  .ProseMirror h2 {
    @apply my-3 text-xl font-bold;
  }

  .ProseMirror h3 {
    @apply my-2 text-lg font-bold;
  }

  .ProseMirror ul,
  .ProseMirror ol {
    @apply my-2 ml-4;
  }

  .ProseMirror li {
    @apply my-1;
  }

  .ProseMirror code {
    @apply rounded bg-gray-100 px-2 py-1 font-mono text-sm dark:bg-gray-800;
  }

  .ProseMirror pre {
    @apply my-2 rounded-lg bg-gray-900 p-4 text-gray-100;
  }

  .ProseMirror pre code {
    @apply bg-transparent p-0;
  }

  .ProseMirror blockquote {
    @apply my-2 border-l-4 border-gray-300 pl-4 italic dark:border-gray-700;
  }

  .ProseMirror img {
    @apply my-2 max-w-full rounded-lg;
  }

  .ProseMirror a {
    @apply text-blue-600 underline dark:text-blue-400;
  }

  .ProseMirror mark {
    @apply bg-yellow-200 dark:bg-yellow-900;
  }

  .ProseMirror table {
    @apply my-2 w-full border-collapse border border-gray-300 dark:border-gray-700;
  }

  .ProseMirror th {
    @apply border border-gray-300 bg-gray-100 p-2 dark:border-gray-700 dark:bg-gray-800;
  }

  .ProseMirror td {
    @apply border border-gray-300 p-2 dark:border-gray-700;
  }

  .is-editor-empty:before {
    @apply pointer-events-none float-left h-0 text-gray-400 content-['attr(data-placeholder)'];
  }
</style>
