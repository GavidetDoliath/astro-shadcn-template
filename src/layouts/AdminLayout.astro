---
import '@/styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Admin' } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Admin</title>
    <meta name="robots" content="noindex, nofollow" />
  </head>
  <body>
    <div class="admin-shell">
      <nav class="admin-nav">
        <a href="/admin" class="admin-nav__brand">Admin</a>
        <form method="POST" action="/api/admin/auth/logout" class="admin-nav__form">
          <button type="submit" class="admin-nav__logout">Se déconnecter</button>
        </form>
      </nav>
      <main class="admin-main">
        <slot />
      </main>
    </div>

    <style is:global>
      .admin-shell {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background-color: var(--fond);
        color: var(--encre);
      }

      .admin-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem 2rem;
        background-color: var(--parchemin);
        border-bottom: 1px solid var(--encre);
      }

      .admin-nav__brand {
        font-weight: 600;
        font-size: 1.25rem;
        color: var(--encre);
        text-decoration: none;
      }

      .admin-nav__brand:hover {
        opacity: 0.8;
      }

      .admin-nav__form {
        margin: 0;
      }

      .admin-nav__logout {
        padding: 0.5rem 1rem;
        background-color: var(--sang);
        color: white;
        border: none;
        border-radius: 0.25rem;
        cursor: pointer;
        font-size: 0.875rem;
        font-weight: 500;
      }

      .admin-nav__logout:hover {
        opacity: 0.9;
      }

      .admin-main {
        flex: 1;
        padding: 2rem;
        max-width: 1400px;
        width: 100%;
        margin: 0 auto;
      }

      .admin-main h1 {
        margin-bottom: 1.5rem;
        font-size: 2rem;
        font-weight: 600;
      }

      .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1rem;
        margin-bottom: 2rem;
      }

      .stats-row > div {
        padding: 1rem;
        background-color: var(--parchemin);
        border: 1px solid var(--encre);
        border-radius: 0.25rem;
        font-weight: 500;
      }
    </style>
  </body>
</html>
