# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Required: Service role key (for server-side operations, admin APIs, newsletter)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Newsletter & Email Configuration
# Get API key from https://resend.com
RESEND_API_KEY=re_your-api-key-here
FROM_EMAIL=noreply@example.com
SITE_URL=https://example.com

# Stripe Configuration (for payments)
# Get keys from https://dashboard.stripe.com/
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID=price_your-price-id
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key

# Build Environment
NODE_ENV=development

# Optional: GitHub Pages deployment
# PUBLIC_BASE_URL=/your-repo-name/
