# ============================================================
# Supabase Configuration
# ============================================================
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (for local development with Edge Functions)
# In production, this is auto-injected by Supabase
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# Sensitive Secrets (Supabase Secret Manager)
# ============================================================
# DO NOT add these to .env in production!
# Instead, use: supabase secrets set STRIPE_SECRET_KEY=...
#
# For local development, you can add them here temporarily:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_test_...
# STRIPE_PRICE_ID=price_...
# RESEND_API_KEY=re_...
# FROM_EMAIL=bonjour@laderaison.fr
# SITE_URL=http://localhost:4000

# ============================================================
# Build Configuration
# ============================================================
NODE_ENV=development

# Optional: GitHub Pages deployment
# PUBLIC_BASE_URL=/your-repo-name/
